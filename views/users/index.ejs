<%- include('../partials/header') %>

<div class="container my-4">
    <h2 class="mb-3">User Directory</h2>
    <p class="mb-4">
        This page is a demo built using Node.js/Express.js and EJS templates.
        It demonstrates the List/View design pattern and pulls data dynamically from a JSON file.
        The pictures and content were generated by third party APIs, and involve no actual identities.
    </p>

    <table class="table table-hover table-striped">
        <thead class="thead-dark">
            <tr>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(function(user){ %>
                <tr>
                    <td><a href="/users/view/<%= user.id %>"><%= user.first_name %></a></td>
                    <td><%= user.last_name %></td>
                    <td><%= user.email %></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<%- include('../partials/footer') %>
